# Copy this file to .env and fill in your values.

# Path to the GB921 Excel file. Leave unset for Docker (default is /app/data_source/...).
# Uncomment and set for local dev (relative to repo root when running from backend/):
# EXCEL_PATH=../docs/GB921_Business_Process_Framework_Processes_Excel_v25.5.xlsx

# Directory where annotation Markdown files are written (default works inside Docker)
DATA_DIR=./data

# API keys — at least one is required to use the Chat feature.
# Direct Anthropic API (used when provider = "claude")
ANTHROPIC_API_KEY=

# OpenRouter (used when provider = "openrouter"; supports Claude, Gemini, GPT-4o, etc.)
OPENROUTER_API_KEY=
